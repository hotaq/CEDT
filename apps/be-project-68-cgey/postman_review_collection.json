    "item": [
        {
            "name": "Setup Review: Register Admin (idempotent)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "let res = {};",
                            "try { res = pm.response.json(); } catch (e) {}",
                            "pm.test('Setup review: admin registration handled', function () {",
                            "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400]);",
                            "    if (pm.response.code !== 400) pm.expect(res.success).to.be.true;",
                            "});"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Admin User\",\n  \"telephone\": \"0999999999\",\n  \"email\": \"{{ADMIN_EMAIL}}\",\n  \"password\": \"{{ADMIN_PASSWORD}}\",\n  \"role\": \"admin\"\n}"
                },
                "url": {
                    "raw": "{{BASE_URL}}/register",
                    "host": [
                        "{{BASE_URL}}"
                    ],
                    "path": [
                        "register"
                    ]
                }
            }
        },
