        {
            "name": "===== REVIEW 1: User Add Review =====",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "let res;",
                            "try {",
                            "    res = pm.response.json();",
                            "} catch (e) {",
                            "    pm.test('Response should be JSON', function () {",
                            "        throw new Error('Non-JSON response: ' + pm.response.text());",
                            "    });",
                            "    return;",
                            "}",
                            "pm.test('Review: user created review for company', function () {",
                            "    pm.expect(pm.response.code).to.equal(201);",
                            "    pm.expect(res.success).to.be.true;",
                            "    pm.expect(res.data).to.have.property('rating');",
                            "    pm.expect(res.data).to.have.property('company');",
                            "    pm.expect(res.data).to.have.property('user');",
                            "});",
                            "pm.collectionVariables.set('REVIEW_ID', res.data._id);"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
