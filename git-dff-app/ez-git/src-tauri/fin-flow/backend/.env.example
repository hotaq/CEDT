# Backend Environment Variables
# Copy this to .env and fill in values.

# ── Server ─────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Typhoon API ────────────────────────────────
# Used for both OCR (task 2.2) and structured extraction (task 2.3).
# Get your key from: https://opentyphoon.ai
TYPHOON_API_KEY=your-key-here

# ── Demo Mode ──────────────────────────────────
# Set to true to bypass real API calls and return mock data (for local dev only).
DEMO_MODE=false
